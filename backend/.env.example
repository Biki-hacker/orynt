# ─── Orynt Backend Environment Variables ───
# Copy this file to .env and fill in the values.

# Server port (default: 8080)
PORT=8080

# JWT signing secret — change this in production!
JWT_SECRET=orynt-default-secret-hackathon-2026-key

# Google Gemini API key for the RAG AI chatbot
GEMINI_API_KEY=

# Firebase & Firestore Configuration
USE_FIRESTORE=false
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=path-to-service-account.json

# Redis Configuration
USE_REDIS=false
REDIS_URL=redis://default:your-password@your-endpoint.upstash.io:6379
REDIS_ADDR=localhost:6379


