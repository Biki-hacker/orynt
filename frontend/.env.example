# ─── Orynt Frontend Environment Variables ───
# Copy this file to .env and fill in the values.
# Vite exposes only variables prefixed with VITE_ to client-side code.

# Backend API base URL used by the Vite dev proxy
VITE_API_BASE_URL=http://localhost:8080

# WebSocket backend host (only needed if different from API base)
VITE_WS_HOST=localhost:8080

# Default dev server port
VITE_PORT=3000
